/*
 * Layer 10 (旧Layer 2) Mouse Gestures
 *
 * Bindings:
 */

/ {
    zip_mouse_gesture_l2: zip_mouse_gesture_l2 {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        enable-eager-mode;

        stroke-size = <150>;
        movement-threshold = <20>;
        idle-timeout-ms = <250>;
        gesture-cooldown-ms = <150>;

        focus_url    { pattern = <GESTURE_UP>;    bindings = <&kp LG(UP_ARROW)>; };
        taskbar_prev { pattern = <GESTURE_LEFT>;  bindings = <&kp LG(LS(LEFT))>; };
        taskbar_next { pattern = <GESTURE_RIGHT>; bindings = <&kp LG(LS(RIGHT))>; };
    };
};
